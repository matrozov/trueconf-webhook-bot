# TrueConf Server address (without scheme).
TRUECONF_SERVER=video.example.com

# Authentication: either a ready JWT (takes priority) or a bot account login/password.
# TRUECONF_TOKEN=eyJhbGciOi...
TRUECONF_USERNAME=webhook_bot
TRUECONF_PASSWORD=change_me

# Whether to verify the TrueConf Server SSL certificate.
TRUECONF_VERIFY_SSL=true

# WebSocket port on the TrueConf Server side.
TRUECONF_WEB_PORT=443

# Public base URL used in generated webhook links.
WEBHOOK_PUBLIC_URL=https://bot.example.com

# Where the HTTP server listens for incoming webhooks.
WEBHOOK_HTTP_HOST=0.0.0.0
WEBHOOK_HTTP_PORT=8080

# Path to the JSON state file.
WEBHOOK_STORAGE_PATH=data/webhooks.json

# true — only chat OWNER/ADMIN can manage webhooks. false — any chat participant.
WEBHOOK_ADMIN_ONLY=true

# Per-token rate limit for incoming POST requests (per minute).
WEBHOOK_RATE_LIMIT_PER_MINUTE=60

# Per-IP rate limit for incoming POST requests (per minute); protects against token enumeration.
WEBHOOK_RATE_LIMIT_PER_IP_PER_MINUTE=120

# Maximum POST body size in megabytes (for multipart uploads).
WEBHOOK_MAX_UPLOAD_MB=25

# Maximum number of attachments (images + files) per request.
WEBHOOK_MAX_ATTACHMENTS=10
